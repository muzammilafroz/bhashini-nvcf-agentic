# Copy this file to .env and fill in real values.
# NEVER commit .env — it's in .gitignore.

# Hugging Face write token (needed in Phase 3 to push the model Space)
HF_TOKEN=your_token_here

# Cloud provider: MOCK_NVCF | GCP | AWS | NVCF
CLOUD_PROVIDER=MOCK_NVCF

# GCP settings (only needed if CLOUD_PROVIDER=GCP)
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# Kong / edge settings (needed for CLOUD_PROVIDER=GCP)
# Prefer SSH/VPN tunnels to the Droplet because Kong Admin and Postgres should bind to localhost.
KONG_ADMIN_URL=http://localhost:8001
KONG_STABLE_TARGET_URL=https://your-current-stable-cloud-run-service.run.app
KONG_UPSTREAM_NAME=indictrans-upstream
KONG_SERVICE_NAME=indictrans-service
KONG_ROUTE_NAME=indictrans-route
KONG_ROUTE_PATHS=/infer

# Prometheus URL (needed for production canary health checks)
PROMETHEUS_URL=http://localhost:9090

# Timescale/Postgres event store. Leave unset for local tests that should not write events.
DATABASE_URL=postgresql://kong:change-me@localhost:5432/kong

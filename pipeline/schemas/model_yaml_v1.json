{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NVCF Model Deployment Schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "description": "MUST match the (mock) NVCF function name"
    },
    "type": {
      "type": "string",
      "enum": ["hf-mt", "triton", "vllm", "sglang"]
    },
    "image": {
      "type": "string"
    },
    "gpu": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["type", "count"]
    },
    "ports": {
      "type": "object",
      "properties": {
        "http": {
          "type": "integer"
        }
      },
      "required": ["http"]
    },
    "scaling": {
      "type": "object",
      "properties": {
        "min_instances": {
          "type": "integer",
          "minimum": 0
        },
        "max_instances": {
          "type": "integer",
          "minimum": 1
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["min_instances", "max_instances", "concurrency"]
    },
    "canary": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "initial_traffic_pct": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "promote_after_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "rollback_on": {
          "type": "object",
          "properties": {
            "p95_latency_ms": {
              "type": "integer"
            },
            "error_rate_pct": {
              "type": "number"
            },
            "wer_delta_pct": {
              "type": "number"
            }
          }
        }
      },
      "required": ["enabled"]
    },
    "smoke_test": {
      "type": "object",
      "properties": {
        "input_fixture": {
          "type": "string"
        },
        "max_latency_ms": {
          "type": "integer"
        }
      }
    }
  },
  "required": ["schema_version", "name", "type", "image", "gpu", "ports", "scaling"]
}
